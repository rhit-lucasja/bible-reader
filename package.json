{
    "name": "bible-reader",
    "version": "0.0.1",
    "private": true,
    "packageManager": "npm@10.9.2",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
    },
    "devDependencies": {
        "turbo": "^2.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}