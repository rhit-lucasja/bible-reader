generator client {
    provider = "prisma-client-js"
    moduleFormat  = "commonjs"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

// ---------------------
// Bible Contents
// ---------------------
model Translation {
    id                  String @id      // e.g. "KJV" or "NAB"
    name                String          // e.g. "New American Bible"
    english_name        String
    website             String
    license_url         String
    short_name          String          // e.g. "KJV" or "NAB"
    language            String          // ISO 639 3-letter code, e.g. "eng"
    language_name       String?
    language_english_name String?
    text_direction      String @default("ltr")  // "ltr" | "rtl"
    num_books           Int
    num_chapters        Int
    num_verses          Int

    books               Book[]
}

model Book {
    id                  String          // e.g. "GEN" or "EXO"
    translation_id      String
    name                String          // translation-specific name
    common_name         String          // common canonical name
    title               String?         // a more descriptive name sometimes given by translation
    order               Int             // book order in the translation
    num_chapters        Int
    num_verses          Int

    translation         Translation @relation(fields: [translation_id], references: [id], onDelete: Cascade)
    chapters            Chapter[]

    @@id([id, translation_id])
}

model Chapter {
    number              Int
    book_id             String
    translation_id      String
    num_verses          Int

    book                Book @relation(fields: [book_id, translation_id], references: [id, translation_id], onDelete: Cascade)
    verses              Verse[]
    content_blocks      ChapterContentBlock[]

    @@id([number, book_id, translation_id])
}

model Verse {
    id                  Int @id @default(autoincrement())
    number              Int
    chapter_number      Int
    book_id             String
    translation_id      String
    
    // plaintext, used for embedding and simple display
    text                String
    
    // structured content of verse text, separated on lines
    content             String[]

    // pgvector embedding (768 dimensions for nomic-embed-text)
    // Only populated for one translation to avoid storing redundant
    //   near-idential embeddings for every translation
    embedding           Unsupported("vector(768)")?

    chapter             Chapter @relation(fields: [chapter_number, book_id, translation_id], references: [number, book_id, translation_id], onDelete: Cascade)

    @@unique([number, chapter_number, book_id, translation_id])
    @@index([book_id, translation_id])
    @@index([chapter_number, book_id, translation_id])
}

model ChapterContentBlock {
    id                  Int @id @default(autoincrement())
    chapter_number      Int
    book_id             String
    translation_id      String
    order               Int             // position within chapter, 0-indexed

    block_type          String          // "heading" | "verse" | "line_break"

    // for heading blocks
    heading_text        String?

    // for verse blocks
    verse_number        Int?

    chapter             Chapter @relation(fields: [chapter_number, book_id, translation_id], references: [number, book_id, translation_id], onDelete: Cascade)

    @@index([chapter_number, book_id, translation_id, order])
}

// ---------------------
// User Accounts & Auth
// ---------------------
model User {
    id                  String @id @default(cuid())
    email               String @unique
    emailVerified       DateTime? @map("email_verified")
    name                String?
    image               String?
    createdAt           DateTime @default(now()) @map("created_at")
    updatedAt           DateTime @updatedAt @map("updated_at")

    // User's preferred translation, defaults to NABRE
    preferred_translation_id String @default("NABRE")

    accounts            Account[]
    sessions            Session[]
    bookmarks           Bookmark[]
    search_history      SearchHistory[]
    reading_history     ReadingHistory[]
}

// Auth.js required tables
model Account {
    id                  String @id @default(cuid())
    userId              String
    type                String
    provider            String
    providerAccountId   String
    refresh_token       String? @db.Text
    access_token        String? @db.Text
    expires_at          Int?
    token_type          String?
    scope               String?
    id_token            String? @db.Text
    session_state       String?

    user                User @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    @@unique([provider, providerAccountId])
}

model Session {
    id                  String @id @default(cuid())
    sessionToken        String @unique
    userId              String
    expires             DateTime

    user                User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier          String
    token               String @unique
    expires             DateTime

    @@unique([identifier, token])
}

// ---------------------
// User Activity
// ---------------------
model Bookmark {
    id                  Int @id @default(autoincrement())
    user_id             String
    verse_id            Int
    translation_id      String
    note                String?
    created_at          DateTime @default(now())

    user                User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@unique([user_id, verse_id, translation_id])
}

model SearchHistory {
    id                  Int @id @default(autoincrement())
    user_id             String
    query               String
    search_type         String // "reference" || "keyword" || "semantic"
    created_at          DateTime @default(now())

    user                User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id, created_at])
}

model ReadingHistory {
    id                  Int @id @default(autoincrement())
    user_id             String
    book_id             String
    chapter_number      Int
    translation_id      String
    read_at             DateTime @default(now())

    user                User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id, read_at])
}